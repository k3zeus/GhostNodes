# ══════════════════════════════════════════════════════════════════════════════
# GHOST NODES — SATOSHI (.ENV CONFIGURE)
# Este arquivo mapeia a instalação nativa do Bitcoin Core em seu servidor para os 
# Containers de visualização da Mempool.space de modo seguro.
# ══════════════════════════════════════════════════════════════════════════════

# ── RAÍZ DE ARMAZENAMENTO ──
# DOCKER_ROOT: Diretorio persistente de base de dados do Mempool e cache MariaDB
DOCKER_ROOT=/home/satoshi/nodenation

# ── PORTAS PUBLICADAS ──
# Porta de acesso web na rede local. Exemplo: http://192.168.1.100:8080
MEMPOOL_WEB_PORT=8080

# ── CREDENCIAIS DO BANCO DE DADOS (MariaDB) ──
MEMPOOL_DB_USER=mempool
MEMPOOL_DB_PASS=muda_senha_db_fortemente123
MEMPOOL_DB_ROOT_PASS=muda_root_senha_fortemente123

# ── INTEGRAÇÃO COM SEU BITCOIN NODE ──
# Deixe localhost ou 172.17.0.1 (ponte docker0)
BITCOIN_RPC_HOST=172.17.0.1
BITCOIN_RPC_PORT=8332

# Credenciais criadas na Etapa [2] de satoshi/install.sh (Arquivo bitcoin.conf)
BITCOIN_RPC_USER=satoshi
BITCOIN_RPC_PASS=muda_rpcaquidesenhadeacidenterpc_gen
