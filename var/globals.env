#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════════════╗
# ║  var/globals.env — Variáveis Globais do Projeto              ║
# ║  Ghost Nodes - NodeNation                                    ║
# ║  Fonte canônica de todos os paths, usuários e configurações  ║
# ╚══════════════════════════════════════════════════════════════╝
# v0.2 - 22032026
#
# Uso:
#   source /home/pleb/nodenation/var/globals.env
#
# Este arquivo é carregado automaticamente por lib/init.sh.
# NÃO hardcode paths nos scripts — use as variáveis daqui.
#
[ -n "${_GN_GLOBALS_LOADED:-}" ] && return 0
_GN_GLOBALS_LOADED=1

# ══════════════════════════════════════════════════════════════════════════════
# PROJETO — raiz e identidade
# ══════════════════════════════════════════════════════════════════════════════
GN_PROJECT_NAME="Ghost Nodes - NodeNation"
GN_PROJECT_SHORT="ghostnodes"
GN_VERSION="beta"
GN_REPO_URL="https://github.com/greycitizen/ghostnodes/archive/refs/tags/beta.tar.gz"
GN_REPO_DIR_NAME="ghostnodes-beta"       # nome da pasta após descompactar

# ══════════════════════════════════════════════════════════════════════════════
# SISTEMA — usuário e diretório raiz
# ══════════════════════════════════════════════════════════════════════════════
GN_USER="pleb"
GN_USER_HOME="/home/${GN_USER}"
GN_ROOT="${GN_USER_HOME}/nodenation"     # raiz do projeto

# ══════════════════════════════════════════════════════════════════════════════
# SUBPROJETOS — cada um tem sua pasta e install.sh próprio
# ══════════════════════════════════════════════════════════════════════════════
GN_HALFIN_DIR="${GN_ROOT}/halfin"
GN_SATOSHI_DIR="${GN_ROOT}/satoshi"
GN_NICK_DIR="${GN_ROOT}/nick"
GN_ADAM_DIR="${GN_ROOT}/adam"
GN_FIATJAF_DIR="${GN_ROOT}/fiatjaf"
GN_NASH_DIR="${GN_ROOT}/nash"
GN_CRAIG_DIR="${GN_ROOT}/craig"

# ══════════════════════════════════════════════════════════════════════════════
# HALFIN — paths internos do subprojeto principal
# ══════════════════════════════════════════════════════════════════════════════
HALFIN_DIR="${GN_HALFIN_DIR}"
TOOLS_DIR="${HALFIN_DIR}/tools"
DOCKER_DIR="${HALFIN_DIR}/docker"
LIB_DIR="${HALFIN_DIR}/lib"
VAR_DIR="${HALFIN_DIR}/var"
LOG_DIR="${HALFIN_DIR}/logs"

# ── Dados / banco WiFi ────────────────────────────────────────────────────────
GN_DB_DIR="${HALFIN_DIR}/var"
GN_DB_FILE="${GN_DB_DIR}/wifi_scan.db"
GN_WIFI_LOG="${GN_DB_DIR}/log_scan_wifi.log"

# ── Scripts de ferramentas ────────────────────────────────────────────────────
GN_SCRIPT_SYSTEM="${TOOLS_DIR}/system.sh"
GN_SCRIPT_WIFI_SCAN="${TOOLS_DIR}/wifi_scan.sh"
GN_SCRIPT_WIFI_SHOW="${TOOLS_DIR}/wifi_show.sh"
GN_SCRIPT_WIFI_CONNECT="${TOOLS_DIR}/wifi_connect.sh"
GN_SCRIPT_WPA_IMPORT="${TOOLS_DIR}/wpa_import.sh"
GN_SCRIPT_NM_IMPORT="${TOOLS_DIR}/nm_import.sh"
GN_SCRIPT_DOCKER="${DOCKER_DIR}/docker.sh"

# ══════════════════════════════════════════════════════════════════════════════
# SATOSHI — Bitcoin Node
# ══════════════════════════════════════════════════════════════════════════════
SATOSHI_DIR="${GN_SATOSHI_DIR}"
SATOSHI_SCRIPTS_DIR="${SATOSHI_DIR}/scripts"
SATOSHI_LOG_DIR="${SATOSHI_DIR}/logs"

# Requisitos mínimos de hardware para Satoshi Node
SATOSHI_MIN_RAM_GB=2
SATOSHI_MIN_DISK_GB=400           # full node
SATOSHI_PRUNED_DISK_GB=10         # pruned node
SATOSHI_MIN_DISK_PRUNED_GB=10

# ══════════════════════════════════════════════════════════════════════════════
# HARDWARE — detecção e compatibilidade (populados em runtime pelo pre-install)
# ══════════════════════════════════════════════════════════════════════════════
GN_HW_ARCH=""          # arm64 | x86_64 | armhf
GN_HW_MODEL=""         # OrangePi Zero 3 | Raspberry Pi 4 | Generic x86...
GN_HW_RAM_GB=0
GN_HW_DISK_GB=0
GN_HW_CPU_CORES=0
GN_HW_COMPAT_FILE="${GN_ROOT}/var/hardware.env"   # salvo após detecção

# ══════════════════════════════════════════════════════════════════════════════
# REDE
# ══════════════════════════════════════════════════════════════════════════════
GN_HOSTNAME="halfin"
GN_WPA_CONF="/etc/wpa_supplicant/wpa_supplicant.conf"
GN_NM_DIR="/etc/NetworkManager/system-connections"

# ══════════════════════════════════════════════════════════════════════════════
# USUÁRIO LEGADO (OrangePi OS) — a ser removido na instalação
# ══════════════════════════════════════════════════════════════════════════════
GN_LEGACY_USER="orangepi"

# ══════════════════════════════════════════════════════════════════════════════
# SENHAS PADRÃO — alterar após primeiro login
# ══════════════════════════════════════════════════════════════════════════════
GN_DEFAULT_PASSWORD="Mudar123"    # senha inicial do usuário pleb

# ══════════════════════════════════════════════════════════════════════════════
# ESTADO DE INSTALAÇÃO
# ══════════════════════════════════════════════════════════════════════════════
GN_STATE_FILE="${GN_ROOT}/var/install.state"
GN_HW_COMPAT_FILE="${GN_ROOT}/var/hardware.env"