# ==============================================================================
# GHOST NODES - HALFIN NODE - DOCKER ENVIRONMENT VARIABLES (.env)
# ==============================================================================
# IMPORTANT: Never commit the actual .env file. Edit this file and rename
# it to `.env` locally.
# ==============================================================================

# GLOBAL SYSTEM 
# PUID and PGID ensure containers have correct R/W permissions on host folders
PUID=1000
PGID=1000
TZ=America/Sao_Paulo

# ==============================================================================
# DATA / PERSISTENCE - ROOT DIRECTORY
# Replace with the correct user path (e.g., /home/pleb/nodenation/halfin/docker)
# ==============================================================================
DOCKER_ROOT=/home/pleb/nodenation/halfin/docker

# ==============================================================================
# 1. HEIMDALL (Dashboard)
# ==============================================================================
# Moved to 8080 as requested
HEIMDALL_PORT=8080
HEIMDALL_SSL_PORT=8443
HEIMDALL_CONFIG_DIR=${DOCKER_ROOT}/heimdall/config

# ==============================================================================
# 2. SYNCTHING (P2P Sync)
# ==============================================================================
SYNCTHING_PORT=8384
SYNCTHING_USER=ghostnode
SYNCTHING_PASS=Mudar123
SYNCTHING_CONFIG_DIR=${DOCKER_ROOT}/syncthing/config
SYNCTHING_DATA_DIR=${DOCKER_ROOT}/syncthing/data

# ==============================================================================
# 3. CLOUDFLARED (Tunnel)
# ==============================================================================
# Put your token generated in Cloudflare Zero Trust UI here:
CLOUDFLARED_TOKEN=your_token_here_xyz

# ==============================================================================
# 4. WIREGUARD (WG-Easy VPN)
# ==============================================================================
WG_HOST=your_public_ip_or_ddns.com
WG_PASSWORD=Mudar123
WG_PORT=51820
WG_UI_PORT=51821
WG_ADDRESS=10.8.0.x
WG_CONFIG_DIR=${DOCKER_ROOT}/wireguard/config

# ==============================================================================
# 5. POSTGRES (Database for Nextcloud)
# ==============================================================================
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud_user
POSTGRES_PASSWORD=Mudar123
POSTGRES_DATA_DIR=${DOCKER_ROOT}/postgres/data

# ==============================================================================
# 6. NEXTCLOUD (Personal Cloud)
# ==============================================================================
NEXTCLOUD_PORT=8444
NEXTCLOUD_CONFIG_DIR=${DOCKER_ROOT}/nextcloud/config

# ==============================================================================
# 7. NGINX (Local Reverse Proxy / Web Server)
# ==============================================================================
# Changed to 8082 to free up Port 80 for GhostNodes Dashboard
NGINX_PORT=8082
NGINX_SSL_PORT=443
NGINX_CONF_DIR=${DOCKER_ROOT}/nginx/conf.d
NGINX_HTML_DIR=${DOCKER_ROOT}/nginx/html
NGINX_AUTH_DIR=${DOCKER_ROOT}/nginx/auth

# ==============================================================================
# 8. UPTIME KUMA (Monitoring)
# ==============================================================================
UPTIME_KUMA_PORT=3001
UPTIME_KUMA_DATA_DIR=${DOCKER_ROOT}/uptimekuma/data
