# ==============================================================================
# GHOST NODES - HALFIN NODE - DOCKER ENVIRONMENT VARIABLES (.env)
# ==============================================================================
# IMPORTANTE: Nunca "commite" o arquivo .env real. Edite esse arquivo e o 
# renomeie para `.env` localmente.
# ==============================================================================

# GLOBAL SYSTEM 
# PUID e PGID garantem que os contêineres tenham permissão de leitura/escrita
# corretas nas pastas do usuário na máquina Host (ex: pleb = 1000:1000)
PUID=1000
PGID=1000
TZ=America/Sao_Paulo

# ==============================================================================
# DADOS / PERSISTÊNCIA - DIRETÓRIO RAIZ
# Substitua pelo usuário correto (ex: /home/pleb/nodenation/halfin/docker)
# ==============================================================================
DOCKER_ROOT=/home/pleb/nodenation/halfin/docker

# ==============================================================================
# 1. HEIMDALL (Dashboard)
# ==============================================================================
HEIMDALL_PORT=8080
HEIMDALL_SSL_PORT=8443
HEIMDALL_CONFIG_DIR=${DOCKER_ROOT}/heimdall/config

# ==============================================================================
# 2. SYNCTHING (Sincronização P2P)
# ==============================================================================
SYNCTHING_PORT=8384
SYNCTHING_USER=ghostnode
SYNCTHING_PASS=Mudar123
SYNCTHING_CONFIG_DIR=${DOCKER_ROOT}/syncthing/config
SYNCTHING_DATA_DIR=${DOCKER_ROOT}/syncthing/data

# ==============================================================================
# 3. CLOUDFLARED (Tunnel)
# ==============================================================================
# Coloque seu token gerado na UI do Cloudflare Zero Trust aqui:
CLOUDFLARED_TOKEN=seu_token_aqui_xyz

# ==============================================================================
# 4. WIREGUARD (WG-Easy VPN)
# ==============================================================================
WG_HOST=seu_ip_publico_ou_ddns.com
WG_PASSWORD=Mudar123
WG_PORT=51820
WG_UI_PORT=51821
WG_ADDRESS=10.8.0.x
WG_CONFIG_DIR=${DOCKER_ROOT}/wireguard/config

# ==============================================================================
# 5. POSTGRES (Banco de Dados para Nextcloud)
# ==============================================================================
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud_user
POSTGRES_PASSWORD=Mudar123
POSTGRES_DATA_DIR=${DOCKER_ROOT}/postgres/data

# ==============================================================================
# 6. NEXTCLOUD (Nuvem Pessoal)
# ==============================================================================
NEXTCLOUD_PORT=8444
NEXTCLOUD_CONFIG_DIR=${DOCKER_ROOT}/nextcloud/config

# ==============================================================================
# 7. NGINX (Proxy Reverso Local / Servidor Web)
# ==============================================================================
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_CONF_DIR=${DOCKER_ROOT}/nginx/conf.d
NGINX_HTML_DIR=${DOCKER_ROOT}/nginx/html
NGINX_AUTH_DIR=${DOCKER_ROOT}/nginx/auth

# ==============================================================================
# 8. UPTIME KUMA (Monitoramento)
# ==============================================================================
UPTIME_KUMA_PORT=3001
UPTIME_KUMA_DATA_DIR=${DOCKER_ROOT}/uptimekuma/data

# ==============================================================================
# 9. KEEWEB (Cofre de Senhas)
# ==============================================================================
KEEWEB_PORT=8081
KEEWEB_DATA_DIR=${DOCKER_ROOT}/keeweb/data
