# DASHBOARD WEB — submenu de gerenciamento
# ══════════════════════════════════════════════════════════════════════════════
_cfg_dashboard() {
    while true; do
        banner_root; section "🌐  Dashboard Web — GhostNodes"; echo ""
        local WEB_DIR=""
        for D in "${GN_ROOT}/web" "${GN_TMP_DIR}/web"; do
            [ -d "$D" ] && WEB_DIR="$D" && break
        done
        if [ -z "$WEB_DIR" ]; then
            step_err "Projeto web não encontrado — baixe o projeto primeiro [d]"
            press_enter_or_back; return
        fi
        step_ok "Web dir: $WEB_DIR"
        echo ""
        if systemctl is-active "$WEB_SERVICE" &>/dev/null 2>&1; then
            printf "  ${GREEN}${BOLD}● Dashboard ATIVO${RESET}\n"
        else
            printf "  ${RED}● Dashboard INATIVO${RESET}\n"
        fi
        echo ""
        printf "  ${BOLD}${CYAN}[1]${RESET}  Instalar dependências (pip)\n"
        printf "  ${BOLD}${CYAN}[2]${RESET}  Criar systemd service\n"
        printf "  ${BOLD}${CYAN}[3]${RESET}  Iniciar Dashboard\n"
        printf "  ${BOLD}${CYAN}[4]${RESET}  Parar Dashboard\n"
        printf "  ${BOLD}${CYAN}[5]${RESET}  Status / Logs\n"
        printf "\n  ${BOLD}[0]${RESET}  Voltar  ${BOLD}[q]${RESET}  Sair\n"
        sep
        _menu_read; OPT="$_MENU_OPT"
        case "$OPT" in
            1)  step_info "Instalando dependências Python..."
                local REQ="${WEB_DIR}/backend/requirements.txt"
                if [ -f "$REQ" ]; then
                    pip3 install -r "$REQ" 2>&1 \
                        | tail -5 | while IFS= read -r L; do printf "  ${DIM}%s${RESET}\n" "$L"; done
                    step_ok "Dependências instaladas"
                else
                    step_warn "requirements.txt não encontrado em ${WEB_DIR}/backend/"
                fi
                press_enter_or_back ;;
            2)  step_info "Criando systemd service: ${WEB_SERVICE}..."
                cat > "/etc/systemd/system/${WEB_SERVICE}" << SVCEOF
[Unit]
Description=GhostNodes Sovereign Dashboard
After=network.target

[Service]
Type=simple
User=${GN_USER}
WorkingDirectory=${GN_ROOT}/web/backend
ExecStart=/usr/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 80
Restart=on-failure
RestartSec=5
Environment=GN_ROOT=${GN_ROOT}

[Install]
WantedBy=multi-user.target
SVCEOF
                systemctl daemon-reload
                systemctl enable "$WEB_SERVICE" 2>/dev/null || true
                step_ok "Service criado: ${WEB_SERVICE}"
                press_enter_or_back ;;
            3)  systemctl start "$WEB_SERVICE" 2>/dev/null \
                    && step_ok "Dashboard iniciado" \
                    || step_err "Falha — verifique: journalctl -u $WEB_SERVICE"
                press_enter_or_back ;;
            4)  systemctl stop "$WEB_SERVICE" 2>/dev/null \
                    && step_ok "Dashboard parado" \
                    || step_warn "Não estava rodando"
                press_enter_or_back ;;
            5)  echo ""
                systemctl status "$WEB_SERVICE" 2>&1 \
                    | while IFS= read -r L; do printf "  %s\n" "$L"; done
                echo ""
                step_info "Últimas 15 linhas do log:"
                journalctl -u "$WEB_SERVICE" --no-pager -n 15 2>&1 \
                    | while IFS= read -r L; do printf "  ${DIM}%s${RESET}\n" "$L"; done
                press_enter_or_back ;;
            0|"") return ;;
        esac
    done
}

