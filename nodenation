_cfg_novo_usuario() {
    banner_root; section "👤  Criar Novo Usuário"; echo ""
    printf "  Nome do novo usuário: "; read -r NEW_USER
    NEW_USER="${NEW_USER// /}"
    [ -z "$NEW_USER" ] && { step_err "Nome vazio"; press_enter_or_back; return; }
    ! [[ "$NEW_USER" =~ ^[a-z_][a-z0-9_-]*$ ]] && {
        step_err "Nome inválido. Use letras minúsculas, números, _ ou -"
        press_enter_or_back; return
    }
    id "$NEW_USER" &>/dev/null && { step_warn "Usuário '${NEW_USER}' já existe"; press_enter_or_back; return; }
    adduser --disabled-password --gecos "" "$NEW_USER" || {
        step_err "Falha ao criar usuário"; press_enter_or_back; return
    }
    printf "  Senha para '${NEW_USER}': "; read -rs NEW_PASS; echo ""
    [ -n "$NEW_PASS" ] && echo "${NEW_USER}:${NEW_PASS}" | chpasswd && step_ok "Senha definida"
    confirm "Adicionar ao grupo sudo?" && usermod -aG sudo "$NEW_USER" && step_ok "Adicionado ao sudo"
    step_ok "Usuário '${NEW_USER}' criado"
    press_enter_or_back
}

_cfg_alias_interface() {
    banner_root; section "📡  Renomear Interface de Rede"; echo ""
    local ALIAS_SH="${GN_TMP_DIR}/halfin/tools/alias.sh"
    [ -f "${GN_ROOT}/halfin/tools/alias.sh" ] && ALIAS_SH="${GN_ROOT}/halfin/tools/alias.sh"
    if [ -f "$ALIAS_SH" ]; then
        step_info "Usando tools/alias.sh do projeto..."
        bash "$ALIAS_SH"; press_enter_or_back; return
    fi
    step_info "Interfaces disponíveis:"
    iw dev 2>/dev/null | awk '$1=="Interface"{print "    • "$2}' \
        || ip link show | awk -F': ' '/^[0-9]+:/{print "    • "$2}'
    echo ""
    printf "  Interface a renomear: "; read -r IFACE_OLD
    ip link show "$IFACE_OLD" &>/dev/null || { step_err "Interface não encontrada"; press_enter_or_back; return; }
    printf "  Novo nome: "; read -r IFACE_NEW
    [[ "$IFACE_NEW" =~ ^[a-zA-Z0-9_-]+$ ]] || { step_err "Nome inválido"; press_enter_or_back; return; }
    local MAC; MAC=$(cat "/sys/class/net/${IFACE_OLD}/address" 2>/dev/null)
    tee "/etc/udev/rules.d/70-rename-${IFACE_OLD}.rules" > /dev/null << UDEV
SUBSYSTEM=="net", ACTION=="add", ATTR{address}=="${MAC}", NAME="${IFACE_NEW}"
UDEV
    udevadm control --reload 2>/dev/null || true
    step_ok "${IFACE_OLD} → ${IFACE_NEW} (após reboot)"
    press_enter_or_back
}

_cfg_rede() {
    while true; do
        banner_root; section "🌐  Configuração de Rede"; echo ""
        local WIFI_SH="${GN_TMP_DIR}/halfin/tools/wifi_connect.sh"
        [ -f "${GN_ROOT}/halfin/tools/wifi_connect.sh" ] && WIFI_SH="${GN_ROOT}/halfin/tools/wifi_connect.sh"
        [ -f "$WIFI_SH" ] && printf "  ${BOLD}${CYAN}[1]${RESET}  Conectar Wi-Fi (wifi_connect.sh)\n" \
                           || printf "  ${DIM}[1]  Conectar Wi-Fi — projeto não baixado ainda${RESET}\n"
        printf "  ${BOLD}${CYAN}[2]${RESET}  Configurar IP fixo\n"
        printf "  ${BOLD}${CYAN}[3]${RESET}  Configurar DHCP\n"
        printf "\n  ${BOLD}[0]${RESET}  Voltar  ${BOLD}[q]${RESET}  Sair\n"
        sep
        _menu_read; OPT="$_MENU_OPT"
        case "$OPT" in
            1) [ -f "$WIFI_SH" ] && bash "$WIFI_SH" || step_warn "Script não disponível" ;;
            2) printf "  Interface: "; read -r NIC
               printf "  IP/mask (ex: 192.168.1.100/24): "; read -r IP_ADDR
               printf "  Gateway: "; read -r GW
               printf "  DNS: "; read -r DNS_IP
               ip addr add "$IP_ADDR" dev "$NIC" 2>/dev/null && step_ok "IP configurado" || step_err "Falha"
               ip route add default via "$GW" 2>/dev/null || true
               echo "nameserver ${DNS_IP}" > /etc/resolv.conf ;;
            3) printf "  Interface: "; read -r NIC
               dhclient "$NIC" 2>/dev/null && step_ok "DHCP em ${NIC}" || step_err "Falha" ;;
            0|"") return ;;
        esac
        press_enter_or_back
    done
}

_cfg_sourcelist() {
    while true; do
        banner_root; section "📦  Sources.list  ${RED}⚠ Avançado${RESET}"; echo ""
        printf "  ${RED}${BOLD}ATENÇÃO:${RESET} Alterar incorretamente pode quebrar o sistema.\n\n"
        printf "  ${BOLD}${CYAN}[1]${RESET}  Debian Bookworm oficial ${GREEN}(recomendado)${RESET}\n"
        printf "  ${BOLD}${CYAN}[2]${RESET}  Debian Bullseye oficial\n"
        printf "  ${BOLD}${CYAN}[3]${RESET}  Editar manualmente (nano)\n"
        printf "\n  ${BOLD}[0]${RESET}  Voltar  ${BOLD}[q]${RESET}  Sair\n"
        sep
        _menu_read; OPT="$_MENU_OPT"
        cp /etc/apt/sources.list "/etc/apt/sources.list.bak.$(date +%Y%m%d%H%M%S)" 2>/dev/null || true
        case "$OPT" in
            1) tee /etc/apt/sources.list > /dev/null << 'SRC'
deb http://deb.debian.org/debian bookworm main contrib non-free non-free-firmware
deb http://deb.debian.org/debian bookworm-updates main contrib non-free non-free-firmware
deb http://deb.debian.org/debian bookworm-backports main contrib non-free non-free-firmware
deb http://security.debian.org/debian-security bookworm-security main contrib non-free non-free-firmware
SRC
               step_ok "Debian Bookworm configurado" ;;
            2) tee /etc/apt/sources.list > /dev/null << 'SRC'
deb http://deb.debian.org/debian bullseye main contrib non-free
deb http://deb.debian.org/debian bullseye-updates main contrib non-free
deb http://security.debian.org/debian-security bullseye-security main contrib non-free
SRC
               step_ok "Debian Bullseye configurado" ;;
            3) nano /etc/apt/sources.list; step_ok "Edição concluída" ;;
            0|"") return ;;
        esac
        press_enter_or_back
    done
}

_cfg_update() {
    banner_root; section "🔄  Atualizar Sistema"; echo ""
    set +e
    step_info "apt-get update..."
    DEBIAN_FRONTEND=noninteractive apt-get update -q 2>&1 \
        | while IFS= read -r L; do printf "  ${DIM}%s${RESET}\n" "$L"; done
    local UPG; UPG=$(apt list --upgradable 2>/dev/null | grep -c "/" || true)
    set -e
    if [ "$UPG" -eq 0 ]; then step_ok "Sistema já atualizado"; press_enter_or_back; return; fi
    step_info "${UPG} pacote(s) disponível(is)"
    if confirm "Executar upgrade?"; then
        sep
        set +e
        DEBIAN_FRONTEND=noninteractive apt-get upgrade -y 2>&1 \
            | while IFS= read -r L; do
                echo "$L" | grep -qiE "^E:|error|fatal" \
                    && printf "  ${RED}%s${RESET}\n" "$L" \
                    || printf "  ${DIM}%s${RESET}\n" "$L"
              done
        set -e; sep
        step_ok "Upgrade concluído"
    fi
    press_enter_or_back
}

