# ══════════════════════════════════════════════════════════════════════════════
# DETECÇÃO DE HARDWARE — salva em /tmp (não em GN_ROOT)
# ══════════════════════════════════════════════════════════════════════════════
detect_hardware() {
    section "🖥   Detecção de Hardware"
    echo ""

    GN_HW_ARCH=$(uname -m 2>/dev/null || echo "unknown")
    case "$GN_HW_ARCH" in
        aarch64) GN_HW_ARCH="arm64" ;;
        x86_64)  GN_HW_ARCH="x86_64" ;;
        armv7l)  GN_HW_ARCH="armhf" ;;
    esac

    GN_HW_MODEL=$(cat /proc/device-tree/model 2>/dev/null | tr -d '\0' \
        || cat /sys/firmware/devicetree/base/model 2>/dev/null | tr -d '\0' \
        || grep -m1 "^model name" /proc/cpuinfo 2>/dev/null | cut -d: -f2 | sed 's/^ *//' \
        || echo "Generic $(uname -m)")

    GN_HW_CPU_CORES=$(nproc 2>/dev/null || grep -c "^processor" /proc/cpuinfo 2>/dev/null || echo "1")

    local RAM_KB; RAM_KB=$(awk '/^MemTotal/{print $2}' /proc/meminfo 2>/dev/null || echo "0")
    GN_HW_RAM_GB=$(( RAM_KB / 1024 / 1024 ))
    [ "$RAM_KB" -gt 524288 ] && [ "$GN_HW_RAM_GB" -eq 0 ] && GN_HW_RAM_GB=1

    local DISK_KB; DISK_KB=$(df / 2>/dev/null | awk 'NR==2{print $2}' || echo "0")
    GN_HW_DISK_GB=$(( DISK_KB / 1024 / 1024 ))

    GN_HW_OS=$(grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d'"' -f2 || echo "Unknown")

    printf "  ${DIM}%-20s${RESET} ${BOLD}%s${RESET}\n" "Modelo:"      "$GN_HW_MODEL"
    printf "  ${DIM}%-20s${RESET} ${BOLD}%s${RESET}\n" "Arquitetura:" "$GN_HW_ARCH"
    printf "  ${DIM}%-20s${RESET} ${BOLD}%s cores${RESET}\n" "CPU:"   "$GN_HW_CPU_CORES"
    printf "  ${DIM}%-20s${RESET} ${BOLD}%s GB${RESET}\n" "RAM:"      "$GN_HW_RAM_GB"
    printf "  ${DIM}%-20s${RESET} ${BOLD}%s GB${RESET}\n" "Disco (/):" "$GN_HW_DISK_GB"
    printf "  ${DIM}%-20s${RESET} ${BOLD}%s${RESET}\n" "Sistema:"     "$GN_HW_OS"
    echo ""

    # Salva em /tmp (não em GN_ROOT — usuário pode não existir ainda)
    mkdir -p "$GN_TMP_VAR"
    cat > "$GN_TMP_HW" << HWENV
# hardware.env — gerado em $(date '+%F %T')
GN_HW_ARCH="${GN_HW_ARCH}"
GN_HW_MODEL="${GN_HW_MODEL}"
GN_HW_CPU_CORES="${GN_HW_CPU_CORES}"
GN_HW_RAM_GB="${GN_HW_RAM_GB}"
GN_HW_DISK_GB="${GN_HW_DISK_GB}"
GN_HW_OS="${GN_HW_OS}"
HWENV
    step_ok "Hardware salvo em: $GN_TMP_HW"
}

# ══════════════════════════════════════════════════════════════════════════════
# COMPATIBILIDADE
# ══════════════════════════════════════════════════════════════════════════════
check_compat() {
    local PROJECT="$1"
    _COMPAT_MSG=""; _COMPAT_WARNINGS=(); _COMPAT_MODE=""
    local RC=0
    local hw_arch="${GN_HW_ARCH:-unknown}"
    local hw_ram="${GN_HW_RAM_GB:-0}"
    local hw_disk="${GN_HW_DISK_GB:-0}"

    case "$PROJECT" in
        halfin)
            if [ "$hw_arch" != "arm64" ]; then
                _COMPAT_MSG="Halfin é otimizado para arm64. Arch atual: ${hw_arch}."
                _COMPAT_WARNINGS+=("Hardware não é arm64 — funcionalidade limitada")
                RC=1
            fi
            ;;
        satoshi)
            if [ "$hw_ram" -lt 1 ]; then
                _COMPAT_MSG="RAM insuficiente (${hw_ram}GB). Mínimo: 1GB."
                RC=2
            elif [ "$hw_disk" -ge 1024 ]; then
                _COMPAT_MODE="full"
                _COMPAT_MSG="Disco compatível com Full Node Bitcoin."
                if [ "$hw_ram" -lt 2 ]; then
                    _COMPAT_WARNINGS+=("RAM abaixo do ideal para Full Node (2GB+ recomendado)")
                    RC=1
                fi
            elif [ "$hw_disk" -ge 10 ]; then
                _COMPAT_MODE="pruned"
                _COMPAT_MSG="Disco ${hw_disk}GB — abaixo do recomendado para Full Node (1TB+)."
                _COMPAT_WARNINGS+=("Será instalado como Pruned Node (~10GB)")
                RC=1
            else
                _COMPAT_MSG="Disco insuficiente (${hw_disk}GB). Mínimo: 10GB."
                RC=2
            fi
            ;;
        *)
            _COMPAT_MSG="Subprojeto '${PROJECT}' sem verificação de compatibilidade."
            RC=1
            ;;
    esac
    return $RC
}

satoshi_default_version() {
    case "${1:-core}" in
        core) echo "29.1" ;;
        knots) echo "29.3.knots20260210" ;;
        *) echo "" ;;
    esac
}

satoshi_recommended_mode() {
    local disk_gb="${GN_HW_DISK_GB:-0}"
    if [ "$disk_gb" -ge 1024 ] 2>/dev/null; then
        echo "full"
    else
        echo "pruned"
    fi
}

satoshi_reset_selection() {
    unset SATOSHI_VARIANT SATOSHI_VERSION SATOSHI_PRUNE_GB SATOSHI_PLAN_LABEL
}

satoshi_prepare_auto_selection() {
    satoshi_reset_selection
    SATOSHI_VARIANT="core"
    SATOSHI_VERSION="$(satoshi_default_version "$SATOSHI_VARIANT")"
    GN_INSTALL_MODE="$(satoshi_recommended_mode)"
    if [ "$GN_INSTALL_MODE" = "pruned" ]; then
        SATOSHI_PRUNE_GB="30"
    fi
    SATOSHI_PLAN_LABEL="Instalação automática"
}

satoshi_prepare_manual_selection() {
    local variant_opt version_input mode_opt prune_opt max_prune_gb custom_prune_gb

    satoshi_reset_selection

    while true; do
        banner_root
        section "₿  Satoshi Node — Escolha da Implementação"
        echo ""
        printf "  ${BOLD}${CYAN}[1]${RESET}  Bitcoin Core\n"
        printf "  ${BOLD}${CYAN}[2]${RESET}  Bitcoin Knots\n"
        printf "\n  ${BOLD}[0]${RESET}  Voltar  ${BOLD}[q]${RESET}  Sair\n"
        sep
        _menu_read; variant_opt="$_MENU_OPT"
        case "$variant_opt" in
            1) SATOSHI_VARIANT="core"; break ;;
            2) SATOSHI_VARIANT="knots"; break ;;
            0|"") return 1 ;;
        esac
    done

    banner_root
    section "₿  Satoshi Node — Versão"
    echo ""
    printf "  ${DIM}Implementação escolhida:${RESET} ${BOLD}%s${RESET}\n" "$SATOSHI_VARIANT"
    printf "  ${DIM}Versão padrão:${RESET} ${BOLD}%s${RESET}\n" "$(satoshi_default_version "$SATOSHI_VARIANT")"
    echo ""
    printf "  Digite a versão desejada ou pressione ENTER para usar a padrão: "
    read -r version_input
    SATOSHI_VERSION="${version_input:-$(satoshi_default_version "$SATOSHI_VARIANT")}"

    while true; do
        banner_root
        section "₿  Satoshi Node — Modo do Node"
        echo ""
        printf "  ${BOLD}${CYAN}[1]${RESET}  Full Node\n"
        if [ "${GN_HW_DISK_GB:-0}" -lt 1024 ] 2>/dev/null; then
            printf "      ${YELLOW}Aviso:${RESET} hardware detectado com menos de 1TB livre\n"
        fi
        printf "  ${BOLD}${CYAN}[2]${RESET}  Pruned Node\n"
        printf "\n  ${BOLD}[0]${RESET}  Voltar  ${BOLD}[q]${RESET}  Sair\n"
        sep
        _menu_read; mode_opt="$_MENU_OPT"
        case "$mode_opt" in
            1)
                GN_INSTALL_MODE="full"
                if [ "${GN_HW_DISK_GB:-0}" -lt 1024 ] 2>/dev/null; then
                    if ! confirm "Seu disco tem menos de 1TB livre. Continuar com Full Node?" "n"; then
                        continue
                    fi
                fi
                break
                ;;
            2)
                GN_INSTALL_MODE="pruned"
                max_prune_gb="${GN_HW_DISK_GB:-10}"
                while true; do
                    banner_root
                    section "₿  Satoshi Node — Tamanho do Pruned"
                    echo ""
                    printf "  ${BOLD}${CYAN}[1]${RESET}  10 GB\n"
                    printf "  ${BOLD}${CYAN}[2]${RESET}  30 GB\n"
                    printf "  ${BOLD}${CYAN}[3]${RESET}  Escolher manualmente\n"
                    printf "\n  ${BOLD}[0]${RESET}  Voltar  ${BOLD}[q]${RESET}  Sair\n"
                    sep
                    _menu_read; prune_opt="$_MENU_OPT"
                    case "$prune_opt" in
                        1) SATOSHI_PRUNE_GB="10"; break ;;
                        2) SATOSHI_PRUNE_GB="30"; break ;;
                        3)
                            echo ""
                            printf "  Espaço máximo do pruned em GB (10-%s): " "$max_prune_gb"
                            read -r custom_prune_gb
                            if ! [[ "$custom_prune_gb" =~ ^[0-9]+$ ]]; then
                                step_warn "Valor inválido"
                                sleep 1
                                continue
                            fi
                            if [ "$custom_prune_gb" -lt 10 ] || [ "$custom_prune_gb" -gt "$max_prune_gb" ]; then
                                step_warn "Valor fora do intervalo permitido"
                                sleep 1
                                continue
                            fi
                            SATOSHI_PRUNE_GB="$custom_prune_gb"
                            break
                            ;;
                        0|"") continue 2 ;;
                    esac
                    break
                done
                break
                ;;
            0|"") return 1 ;;
        esac
    done

    SATOSHI_PLAN_LABEL="Instalação manual"
    return 0
}

# ══════════════════════════════════════════════════════════════════════════════
# DOWNLOAD — baixa para /tmp/ghostnodes_staging (NUNCA para GN_ROOT ainda)
# ══════════════════════════════════════════════════════════════════════════════
download_project() {
    section "📥  Download — ${GN_PROJECT_NAME}"
    echo ""

    local TARBALL="/tmp/ghostnodes_main.tar.gz"
    local EXTRACT_PARENT="/tmp"

    # Verifica se staging já existe e está completo
    if [ -d "$GN_TMP_DIR" ] && [ -f "${GN_TMP_DIR}/halfin/lib/init.sh" ]; then
        step_ok "Projeto já em staging: $GN_TMP_DIR"
        if ! confirm "Baixar novamente?"; then
            return 0
        fi
        rm -rf "$GN_TMP_DIR"
    fi

    # Download
    if [ -f "$TARBALL" ]; then
        if [ ! -t 0 ] || [ "${GN_AUTO_INSTALL:-false}" = "true" ]; then
            step_info "Modo Silencioso/Bootstrap: Forçando download e invalidando cache."
            rm -f "$TARBALL"
        elif confirm "Cache encontrado. Usar?"; then
            step_ok "Usando cache: $TARBALL"
        else
            rm -f "$TARBALL"
        fi
    fi

    if [ ! -f "$TARBALL" ]; then
        step_info "Baixando de:\n    ${DIM}${GN_REPO_URL}${RESET}"
        echo ""
        if command -v wget &>/dev/null; then
            wget -q --show-progress -O "$TARBALL" "$GN_REPO_URL" || {
                step_err "Falha no download (wget)"; return 1
            }
        elif command -v curl &>/dev/null; then
            curl -fSL --progress-bar -o "$TARBALL" "$GN_REPO_URL" || {
                step_err "Falha no download (curl)"; return 1
            }
        else
            step_err "wget ou curl não encontrado — instale um deles"
            return 1
        fi
        step_ok "Download: $(du -sh "$TARBALL" 2>/dev/null | cut -f1)"
    fi

    echo ""

    # Extrai em /tmp
    step_info "Extraindo em /tmp ..."
    rm -rf "${EXTRACT_PARENT}/${GN_REPO_DIR_NAME}" "$GN_TMP_DIR"
    tar -xzf "$TARBALL" -C "$EXTRACT_PARENT" 2>/dev/null || {
        step_err "Falha na extração"; return 1
    }

    # Localiza pasta extraída
    local EXTRACTED
    EXTRACTED=$(find "$EXTRACT_PARENT" -maxdepth 1 -type d -iname "ghostnodes*" 2>/dev/null | head -1)
    # Fallback: tenta nome exato do repo se find falhou
    if [ -z "$EXTRACTED" ] || [ ! -d "$EXTRACTED" ]; then
        [ -d "${EXTRACT_PARENT}/${GN_REPO_DIR_NAME}" ] && EXTRACTED="${EXTRACT_PARENT}/${GN_REPO_DIR_NAME}"
    fi
    if [ -z "$EXTRACTED" ] || [ ! -d "$EXTRACTED" ]; then
        step_err "Pasta extraída não encontrada em $EXTRACT_PARENT"
        step_info "Esperado: ${GN_REPO_DIR_NAME} ou ghostnodes*"
        return 1
    fi

    # Renomeia para ghostnodes_staging
    mv "$EXTRACTED" "$GN_TMP_DIR"
    step_ok "Projeto em staging: $GN_TMP_DIR"

    # Sanitiza (line endings + permissões) no staging
    sanitize_project "$GN_TMP_DIR"

    # Copia auto.sh do staging para GN_TMP_VAR (para ficar acessível antes de mover)
    mkdir -p "$GN_TMP_VAR"
    local AUTO_SRC="${GN_TMP_DIR}/var/auto.sh"
    if [ -f "$AUTO_SRC" ]; then
        cp "$AUTO_SRC" "${GN_TMP_VAR}/auto.sh"
        step_ok "auto.sh copiado para: ${GN_TMP_VAR}/auto.sh"
    else
        step_warn "var/auto.sh não encontrado no projeto — pré-configurações automáticas indisponíveis"
    fi

    rm -f "$TARBALL"
    return 0
}

# ══════════════════════════════════════════════════════════════════════════════
# INSTALA PROJETO — move staging → GN_ROOT (SÓ após usuário existir)
# ══════════════════════════════════════════════════════════════════════════════
instalar_projeto() {
    section "📁  Instalando Projeto em ${GN_ROOT}"
    echo ""

    # Verifica se o usuário foi criado
    if ! id "$GN_USER" &>/dev/null; then
        step_err "Usuário '${GN_USER}' não existe ainda — execute pre_install.sh primeiro"
        return 1
    fi

    # Verifica se staging existe
    if [ ! -d "$GN_TMP_DIR" ]; then
        step_err "Staging não encontrado: $GN_TMP_DIR — execute download primeiro"
        return 1
    fi

    # Cria home se necessário (o adduser já deveria ter criado)
    mkdir -p "$GN_USER_HOME"

    # Move staging → GN_ROOT
    step_info "Movendo ${GN_TMP_DIR} → ${GN_ROOT}..."
    rm -rf "$GN_ROOT"
    mv "$GN_TMP_DIR" "$GN_ROOT"

    # Cria estrutura de diretórios necessários
    mkdir -p "${GN_ROOT}/var"
    mkdir -p "${GN_ROOT}/halfin/logs"
    mkdir -p "${GN_ROOT}/halfin/var"
    mkdir -p "${GN_ROOT}/satoshi/logs"

    # Migra arquivos temporários de /tmp para o projeto definitivo
    [ -f "$GN_TMP_HW" ] && {
        cp "$GN_TMP_HW" "${GN_ROOT}/var/hardware.env"
        step_ok "hardware.env migrado para ${GN_ROOT}/var/"
    }
    [ -f "$GN_TMP_STATE" ] && {
        cp "$GN_TMP_STATE" "${GN_ROOT}/var/install.state"
        step_ok "install.state migrado"
    }

    # Ajusta propriedade
    chown -R "${GN_USER}:${GN_USER}" "$GN_ROOT" 2>/dev/null || true

    # Instala ghostnode como comando global
    if [ -f "${GN_ROOT}/halfin/ghostnode" ]; then
        cp "${GN_ROOT}/halfin/ghostnode" /usr/local/bin/ghostnode
        chmod +x /usr/local/bin/ghostnode
        step_ok "Comando 'ghostnode' instalado em /usr/local/bin/"
    fi

    step_ok "Projeto instalado em: $GN_ROOT"
    return 0
}

# ══════════════════════════════════════════════════════════════════════════════
# SANITIZE — line endings + permissões + integridade
# ══════════════════════════════════════════════════════════════════════════════
sanitize_project() {
    local PROJECT_ROOT="$1"
    local WARN_COUNT=0
    echo ""
    step_info "Sanitizando: $PROJECT_ROOT"

    # 1. Line endings CRLF → LF
    if command -v dos2unix &>/dev/null; then
        find "$PROJECT_ROOT" -type f \( -name "*.sh" -o -name "*.env" -o -name "*.conf" \) \
            -print0 2>/dev/null | xargs -0 dos2unix -q 2>/dev/null || true
        find "$PROJECT_ROOT" -type f ! -name "*.*" -print0 2>/dev/null \
            | while IFS= read -r -d '' F; do
                head -c 2 "$F" 2>/dev/null | grep -q $'#!' && dos2unix -q "$F" 2>/dev/null || true
              done
    else
        find "$PROJECT_ROOT" -type f \( -name "*.sh" -o -name "*.env" \) 2>/dev/null \
            | while read -r F; do sed -i 's/\r$//' "$F" 2>/dev/null || true; done
    fi
    step_ok "Line endings: LF (Unix)"

    # 2. chmod +x em .sh
    find "$PROJECT_ROOT" -type f -name "*.sh" -exec chmod +x {} \; 2>/dev/null || true
    step_ok "chmod +x: todos os .sh"

    # 3. chmod +x em executáveis sem extensão com shebang
    for NAME in ghostnode nodenation; do
        find "$PROJECT_ROOT" -type f -name "$NAME" -exec chmod +x {} \; 2>/dev/null || true
    done
    find "$PROJECT_ROOT" -type f ! -name "*.*" 2>/dev/null | while read -r F; do
        head -c 2 "$F" 2>/dev/null | grep -q $'#!' && chmod +x "$F" 2>/dev/null || true
    done
    step_ok "chmod +x: executáveis sem extensão"

    # 4. Verifica integridade mínima
    local REQUIRED=("halfin/lib/init.sh" "halfin/lib/colors.sh" "halfin/var/globals.env")
    local MISSING=0
    for REL in "${REQUIRED[@]}"; do
        [ ! -f "${PROJECT_ROOT}/${REL}" ] && {
            step_warn "Ausente: $REL"
            WARN_COUNT=$((WARN_COUNT+1)); MISSING=$((MISSING+1))
        }
    done
    [ "$MISSING" -eq 0 ] \
        && step_ok "Integridade: arquivos essenciais presentes" \
        || step_warn "${MISSING} arquivo(s) essencial(is) ausente(s)"
    echo ""
}

# ══════════════════════════════════════════════════════════════════════════════
# AUTO.SH — carrega do staging ou de GN_ROOT
# ══════════════════════════════════════════════════════════════════════════════
_load_auto_sh() {
    # Prioridade: staging/tmp → depois GN_ROOT (se já instalado)
    local AUTO_TMP="${GN_TMP_VAR}/auto.sh"
    local AUTO_ROOT="${GN_ROOT}/var/auto.sh"

    if [ -f "$AUTO_TMP" ]; then
        source "$AUTO_TMP" 2>/dev/null || true
    elif [ -f "$AUTO_ROOT" ]; then
        source "$AUTO_ROOT" 2>/dev/null || true
    fi
}

# Busca pré-config: procura no staging e em GN_ROOT
check_preinstall_exists() {
    local PROJECT="$1"
    _GN_FOUND_SCRIPT=""; _GN_FOUND_DESC=""

    _load_auto_sh

    # Usa gn_find_preinstall do auto.sh se disponível
    if declare -f gn_find_preinstall &>/dev/null; then
        # gn_find_preinstall usa GN_ROOT nos caminhos — ajusta para staging se necessário
        if gn_find_preinstall "$PROJECT"; then
            # Converte path GN_ROOT → staging se o projeto ainda não foi instalado
            if [ ! -d "$GN_ROOT" ] && [ -d "$GN_TMP_DIR" ]; then
                _GN_FOUND_SCRIPT="${_GN_FOUND_SCRIPT/$GN_ROOT/$GN_TMP_DIR}"
            fi
            [ -f "$_GN_FOUND_SCRIPT" ] && return 0
        fi
    fi

    # Fallback direto: procura pre_install.sh no staging ou GN_ROOT
    local CANDIDATES=(
        "${GN_TMP_DIR}/${PROJECT}/pre_install.sh"
        "${GN_TMP_DIR}/halfin/pre_install.sh"
        "${GN_ROOT}/${PROJECT}/pre_install.sh"
        "${GN_ROOT}/halfin/pre_install.sh"
    )
    for C in "${CANDIDATES[@]}"; do
        if [ -f "$C" ]; then
            _GN_FOUND_SCRIPT="$C"
            _GN_FOUND_DESC="Configuração padrão para ${PROJECT} (${GN_HW_MODEL:-hardware detectado})"
            return 0
        fi
    done

    return 1
}

# ══════════════════════════════════════════════════════════════════════════════
# LAUNCH SUBPROJECT — fluxo completo com pré-config
# ══════════════════════════════════════════════════════════════════════════════
launch_subproject() {
    local PROJECT="$1"
    local PROJECT_NAME="$2"

    while true; do
        banner_root
        section "🚀  ${PROJECT_NAME}"
        echo ""

        # Hardware
        printf "  ${BOLD}Hardware:${RESET}\n"
        printf "  ${BULLET} Model : ${BOLD}%s${RESET}\n" "${GN_HW_MODEL:-—}"
        printf "  ${BULLET} Arch  : ${BOLD}%s${RESET}\n" "${GN_HW_ARCH:-—}"
        printf "  ${BULLET} RAM   : ${BOLD}%s GB${RESET}\n" "${GN_HW_RAM_GB:-—}"
        printf "  ${BULLET} Disk  : ${BOLD}%s GB${RESET}\n" "${GN_HW_DISK_GB:-—}"
        printf "  ${BULLET} OS    : ${BOLD}%s${RESET}\n" "${GN_HW_OS:-—}"
        echo ""

        # Compatibilidade
        local COMPAT_RC=0
        check_compat "$PROJECT" || COMPAT_RC=$?

        case $COMPAT_RC in
            0) step_ok "Hardware 100% compatível com ${PROJECT_NAME}"
               [ -n "${_COMPAT_MODE:-}" ] && step_info "Modo: ${BOLD}${_COMPAT_MODE}${RESET}" ;;
            1) step_warn "${_COMPAT_MSG}"
               for W in "${_COMPAT_WARNINGS[@]:-}"; do
                   [ -n "$W" ] && printf "    ${WARN} ${YELLOW}%s${RESET}\n" "$W"
               done ;;
            2) step_err "${_COMPAT_MSG}"
               printf "\n  ${RED}Hardware incompatível com ${PROJECT_NAME}.${RESET}\n"
               press_enter_or_back; return ;;
        esac

        echo ""
        sep

        if [ "$PROJECT" = "satoshi" ] && [ -n "${SATOSHI_PLAN_LABEL:-}" ]; then
            printf "\n  ${BOLD}${WHITE}Plano Satoshi Selecionado:${RESET}\n\n"
            printf "  ${BULLET} Fluxo: ${BOLD}%s${RESET}\n" "${SATOSHI_PLAN_LABEL}"
            printf "  ${BULLET} Implementação: ${BOLD}%s${RESET}\n" "${SATOSHI_VARIANT:-core}"
            printf "  ${BULLET} Versão: ${BOLD}%s${RESET}\n" "${SATOSHI_VERSION:-$(satoshi_default_version "${SATOSHI_VARIANT:-core}")}"
            printf "  ${BULLET} Modo: ${BOLD}%s${RESET}\n" "${GN_INSTALL_MODE:-${_COMPAT_MODE:-pruned}}"
            if [ "${GN_INSTALL_MODE:-}" = "pruned" ]; then
                printf "  ${BULLET} Espaço prune: ${BOLD}%s GB${RESET}\n" "${SATOSHI_PRUNE_GB:-30}"
            fi
            echo ""
            sep
        fi

        # Verifica se há pré-configuração disponível
        local HAS_PRE=0
        if check_preinstall_exists "$PROJECT"; then HAS_PRE=1; fi

        printf "\n  ${BOLD}${WHITE}Installation Options:${RESET}\n\n"

        if [ "$HAS_PRE" -eq 1 ]; then
            printf "  ${BOLD}${GREEN}[1]${RESET}  ${BOLD}Automated Installation${RESET}  ${GREEN}◈ Recommended${RESET}\n"
            printf "      ${DIM}Pre-configuration found for this hardware:${RESET}\n"
            printf "      ${DIM}%s${RESET}\n" "$_GN_FOUND_DESC"
            printf "      ${DIM}Script: %s${RESET}\n\n" "${_GN_FOUND_SCRIPT##*/tmp/ghostnodes_staging/}"
        else
            printf "  ${DIM}[1]  Automated Installation — ${YELLOW}not available for this hardware${RESET}\n\n"
        fi

        printf "  ${BOLD}${CYAN}[2]${RESET}  Manual Configuration\n"
        printf "      ${DIM}Create user, sourcelist, network, tools manually${RESET}\n"
        echo ""
        sep
        printf "  ${BOLD}[0]${RESET}  Back  ${BOLD}[q]${RESET}  Quit\n"
        sep

        _menu_read; OPT="$_MENU_OPT"

        case "$OPT" in
            1)
                if [ "$HAS_PRE" -eq 0 ]; then
                    step_warn "Instalação automatizada não disponível para este hardware"
                    sleep 2; continue
                fi
                _executar_pre_install "$PROJECT"
                return
                ;;
            2)
                menu_config_manual
                ;;
            0|"") return ;;
        esac
    done
}

# ── Executa pre_install.sh: garante download → roda → move staging ────────────
_executar_pre_install() {
    local PROJECT="$1"

    # Garante que projeto está no staging
    if [ ! -d "$GN_TMP_DIR" ] || [ ! -f "${GN_TMP_DIR}/halfin/lib/init.sh" ]; then
        step_warn "Projeto não está no staging — fazendo download..."
        download_project || { press_enter_or_back; return; }
        # Re-busca o script após download
        check_preinstall_exists "$PROJECT" || {
            step_err "pre_install.sh não encontrado após download"
            press_enter_or_back; return
        }
    fi

    banner_root
    section "⚙   Executando Pré-Instalação: ${_GN_FOUND_DESC}"
    echo ""
    printf "  ${DIM}Script : %s${RESET}\n" "$_GN_FOUND_SCRIPT"
    printf "  ${DIM}Hardware: %s (%s)${RESET}\n" "${GN_HW_MODEL:-?}" "${GN_HW_ARCH:-?}"
    echo ""
    printf "  ${YELLOW}${BOLD}O pre_install.sh irá:${RESET}\n"
    printf "  ${BULLET} Criar o usuário '${GN_USER}' quando necessário\n"
    if [ "$PROJECT" = "halfin" ]; then
        printf "  ${BULLET} Atualizar sources.list, ferramentas e rede/AP\n"
        printf "  ${BULLET} Configurar extras do Halfin e dashboard web\n"
        printf "  ${BULLET} Remover o usuário legado (orangepi) ao final\n"
    elif [ "$PROJECT" = "satoshi" ]; then
        printf "  ${BULLET} Preparar dependências base do Satoshi Node\n"
        printf "  ${BULLET} Promover o staging e executar o instalador Bitcoin\n"
        printf "  ${BULLET} Configurar bitcoin.conf, RPC e systemd\n"
    fi
    echo ""
    printf "  ${RED}Após criar o usuário '${GN_USER}', o projeto será\n"
    printf "  movido de /tmp para /home/${GN_USER}/nodenation/${RESET}\n"
    echo ""

    if ! confirm "Iniciar instalação automatizada?"; then
        return
    fi

    # Exporta variáveis de contexto para o pre_install.sh
    export GN_HW_ARCH GN_HW_MODEL GN_HW_RAM_GB GN_HW_DISK_GB GN_HW_CPU_CORES GN_HW_OS
    export GN_INSTALL_MODE="${GN_INSTALL_MODE:-${_COMPAT_MODE:-standard}}"
    export GN_ROOT GN_USER GN_TMP_DIR
    export SATOSHI_VARIANT="${SATOSHI_VARIANT:-}"
    export SATOSHI_VERSION="${SATOSHI_VERSION:-}"
    export SATOSHI_PRUNE_GB="${SATOSHI_PRUNE_GB:-}"

    echo ""
    sep
    step_info "Iniciando: $_GN_FOUND_SCRIPT"
    sep
    echo ""

    bash "$_GN_FOUND_SCRIPT"
    local RC=$?

    sep
    echo ""

    if [ $RC -ne 0 ]; then
        step_warn "pre_install.sh retornou código $RC — verifique os logs"
        press_enter_or_back; return
    fi

    step_ok "Pré-instalação concluída"
    echo ""

    # Agora que o usuário foi criado, move staging → GN_ROOT
    if id "$GN_USER" &>/dev/null; then
        instalar_projeto
        if [ "$PROJECT" = "halfin" ] && [ -f "${GN_ROOT}/halfin/docker/docker.sh" ]; then
            step_info "Inicializando instalação do Docker e Orchestration..."
            export GN_AUTO_INSTALL="true"
            export AUTO_INSTALL="true"
            bash "${GN_ROOT}/halfin/docker/docker.sh" || step_warn "Aviso: Falha na orquestração pelo docker.sh"
        elif [ "$PROJECT" = "satoshi" ] && [ -f "${GN_ROOT}/satoshi/install.sh" ]; then
            step_info "Inicializando instalação automatizada do Satoshi Node..."
            export GN_AUTO_INSTALL="true"
            export SATOSHI_VARIANT="${SATOSHI_VARIANT:-core}"
            export SATOSHI_VERSION="${SATOSHI_VERSION:-$(satoshi_default_version "${SATOSHI_VARIANT:-core}")}"
            export SATOSHI_PRUNE_GB="${SATOSHI_PRUNE_GB:-30}"
            bash "${GN_ROOT}/satoshi/install.sh" || step_warn "Aviso: Falha na instalação automatizada do Satoshi Node"
        fi
    else
        step_warn "Usuário '${GN_USER}' não foi criado — projeto permanece em ${GN_TMP_DIR}"
        step_info "Execute manualmente: instalar_projeto"
    fi

    press_enter_or_back
}

