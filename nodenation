#!/bin/bash
#
# ╔══════════════════════════════════════════════════════════════╗
# ║  nodenation — Ghost Nodes · NodeNation                       ║
# ║  Bootstrap · Menu Principal · Pre-Install                    ║
# ║  v0.15 — 2026                                                ║
# ╚══════════════════════════════════════════════════════════════╝
#
# Uso:
#   curl -fsSL https://raw.githubusercontent.com/greycitizen/ghostnodes/refs/heads/main/nodenation | sudo bash
#   sudo bash nodenation [--help | --download-only | --detect-hw]
#
# Fluxo correto:
#   1. Detecta hardware e SO → salva em /tmp
#   2. Baixa projeto → descompacta em /tmp/ghostnodes_staging/
#   3. Carrega auto.sh do staging (não de GN_ROOT!)
#   4. Menu principal com subprojetos
#   5. Ao escolher halfin: mostra pré-config encontrada para o hardware
#   6. Usuário confirma → pre_install.sh cria o usuário pleb
#   7. SÓ ENTÃO: move /tmp/staging → /home/pleb/nodenation
#

# ══════════════════════════════════════════════════════════════════════════════
# BOOTSTRAP — suporte a curl | bash (stdin não é TTY)
# ══════════════════════════════════════════════════════════════════════════════
if [ ! -t 0 ]; then
    _SELF="/tmp/nodenation_bootstrap.sh"
    cat > "$_SELF" && chmod +x "$_SELF"
    exec bash "$_SELF" "$@" < /dev/tty
fi

set -euo pipefail

# ══════════════════════════════════════════════════════════════════════════════
# CONFIGURAÇÃO GLOBAL
# ══════════════════════════════════════════════════════════════════════════════

