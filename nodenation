menu_principal() {
    while true; do
        banner_root

        # Linha de status
        local HNOW; HNOW=$(hostname 2>/dev/null || echo "—")
        local UPNOW; UPNOW=$(uptime -p 2>/dev/null | sed 's/up //' || echo "—")
        printf "  ${DIM}Node: ${WHITE}%-15s${RESET}  ${DIM}Up: %-20s${RESET}  ${DIM}User: %s${RESET}\n\n" \
               "$HNOW" "$UPNOW" "${SUDO_USER:-$(whoami)}"

        # Status do projeto
        local STAGING_OK=0 ROOT_OK=0
        [ -d "$GN_TMP_DIR" ] && [ -f "${GN_TMP_DIR}/halfin/lib/init.sh" ] && STAGING_OK=1
        [ -d "$GN_ROOT" ]    && [ -f "${GN_ROOT}/halfin/lib/init.sh" ]    && ROOT_OK=1

        if [ "$ROOT_OK" -eq 1 ]; then
            printf "  ${GREEN}${BOLD}✔ Project installed:${RESET} ${GN_ROOT}\n\n"
        elif [ "$STAGING_OK" -eq 1 ]; then
            printf "  ${YELLOW}⟳ Project in staging:${RESET} ${GN_TMP_DIR}\n"
            printf "  ${DIM}  (awaiting user creation for final installation)${RESET}\n\n"
        else
            printf "  ${RED}✘ Project not downloaded.${RESET} Use ${BOLD}[d]${RESET} to download.\n\n"
        fi

        sep
        printf "  ${BOLD}${WHITE}Subprojects:${RESET}\n"
        sep_thin
        echo ""
        printf "  ${BOLD}${CYAN}[1]${RESET}  ${BOLD}Halfin Node${RESET}     ${GREEN}◈${RESET}  ${DIM}AP/Router — OrangePi Zero 3 — arm64${RESET}\n"
        printf "  ${BOLD}${CYAN}[2]${RESET}  ${BOLD}Satoshi Node${RESET}    ${YELLOW}₿${RESET}  ${DIM}Bitcoin Full/Pruned — arm64/x86_64${RESET}\n"
        printf "  ${BOLD}${CYAN}[3]${RESET}  ${BOLD}Nick Node${RESET}       ${DIM}…  Coming Soon${RESET}\n"
        printf "  ${BOLD}${CYAN}[4]${RESET}  ${BOLD}Adam Node${RESET}       ${DIM}…  Coming Soon${RESET}\n"
        printf "  ${BOLD}${CYAN}[5]${RESET}  ${BOLD}Fiatjaf Node${RESET}    ${DIM}…  Coming Soon${RESET}\n"
        printf "  ${BOLD}${CYAN}[6]${RESET}  ${BOLD}Nash Node${RESET}       ${DIM}…  Coming Soon${RESET}\n"
        printf "  ${BOLD}${CYAN}[7]${RESET}  ${BOLD}Craig Node${RESET}      ${DIM}…  Coming Soon${RESET}\n"
        echo ""
        sep_thin
        echo ""
        printf "  ${BOLD}[d]${RESET}  Download / Update project\n"
        printf "  ${BOLD}[h]${RESET}  Detect Hardware\n"
        printf "  ${BOLD}[c]${RESET}  Manual System Configuration\n"
        printf "  ${BOLD}[?]${RESET}  Help\n"
        echo ""
        sep
        printf "  ${BOLD}[q]${RESET}  Quit\n"
        sep

        _menu_read; OPT="$_MENU_OPT"

        case "$OPT" in
            1) launch_subproject "halfin"  "Halfin Node" ;;
            2) menu_satoshi ;;
            3|4|5|6|7) menu_coming_soon "Subproject" ;;
            d|D) download_project; press_enter_or_back ;;
            h|H) detect_hardware; press_enter_or_back ;;
            c|C) menu_config_manual ;;
            "?") show_help ;;
            0|"") : ;;
        esac
    done
}

main() {
    if [ "$EUID" -ne 0 ]; then
        printf "\n  ${RED}[ERRO]${RESET} Execute como root: ${BOLD}sudo bash nodenation${RESET}\n\n"
        exit 1
    fi

    mkdir -p "$GN_TMP_DIR" "$GN_TMP_VAR" 2>/dev/null || true

    [ -f "${LIB_DIR}/init.sh" ] && source "${LIB_DIR}/init.sh" 2>/dev/null || true

    for HW_F in "$GN_TMP_HW" "${GN_ROOT}/var/hardware.env"; do
        [ -f "$HW_F" ] && source "$HW_F" 2>/dev/null && break || true
    done

    case "${1:-}" in
        --help|-h)
            detect_hardware 2>/dev/null || true
            show_help
            ;;
        --download-only)
            detect_hardware
            download_project
            exit 0
            ;;
        --detect-hw)
            detect_hardware
            exit 0
            ;;
        --web-start)
            echo "🚀 Starting GhostNodes Dashboard service..."
            sudo systemctl start "$WEB_SERVICE" || true
            sudo systemctl status "$WEB_SERVICE"
            exit 0
            ;;
        --web-stop)
            echo "🛑 Stopping GhostNodes Dashboard service..."
            sudo systemctl stop "$WEB_SERVICE" || true
            exit 0
            ;;
        --web-status)
            echo "🔍 Checking Dashboard status..."
            sudo systemctl status "$WEB_SERVICE"
            exit 0
            ;;
        *)
            [ -z "${GN_HW_ARCH:-}" ] && detect_hardware
            if [ ! -d "$GN_TMP_DIR" ] || [ ! -f "${GN_TMP_DIR}/halfin/lib/init.sh" ]; then
                if [ ! -d "$GN_ROOT" ] || [ ! -f "${GN_ROOT}/halfin/lib/init.sh" ]; then
                    echo ""
                    step_info "Projeto não encontrado — iniciando download automático..."
                    press_enter
                    download_project || true
                fi
            fi
            menu_principal
            ;;
    esac
}

if [ "$_GN_EXECUTED_DIRECTLY" -eq 1 ]; then
    main "$@"
fi
