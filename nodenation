        echo ""
        sep
        printf "  ${BOLD}[0]${RESET}  Voltar  ${BOLD}[q]${RESET}  Sair\n"
        sep

        OPT=$(_menu_read)
        case "$OPT" in
            1) _cfg_novo_usuario ;;
            2) _cfg_alias_interface ;;
            3) _cfg_rede ;;
            4) _cfg_sourcelist ;;
            5) _cfg_update ;;
