        printf "  ${BOLD}${CYAN}[1]${RESET}  Criar novo usuário\n"
        printf "  ${BOLD}${CYAN}[2]${RESET}  Renomear interface de rede (alias)\n"
        printf "  ${BOLD}${CYAN}[3]${RESET}  Configurar conexão de rede\n"
        printf "  ${BOLD}${CYAN}[4]${RESET}  Alterar sources.list  ${RED}${DIM}(avançado)${RESET}\n"
